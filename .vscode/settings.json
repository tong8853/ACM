{
    // 只有当文件名不带后缀，且确实不是 C++ 头文件时才需要手动关联
    "files.associations": {
        "*.tcc": "cpp",
        "*.h": "cpp"  // 强制把 .h 当作 C++，对竞赛非常有用
    },
    
    // 竞赛核心：关闭恼人的红线（波浪线）
    //"C_Cpp.intelliSenseEngine": "disabled", 
    
    // 禁用 C++ 插件的自动格式化（如果你习惯手打缩进或手动排版）
    "C_Cpp.formatting": "disabled",
    
    // 彻底禁用 GitHub Copilot 的所有自动提示
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false
    },

    // 提升写代码手感
    "editor.suggest.snippetsPreventQuickSuggestions": true,
    "editor.formatOnSave": false,

    "editor.inlineSuggest.enabled": false,
    
    "python-envs.defaultEnvManager": "ms-python.python:conda",
    "C_Cpp.default.compilerPath": "D:/Program Files (x86)/mingw64/bin/g++.exe"
}